# Copy to .env and fill in real values. Every var below is required at
# startup (django-environ, ADR 0002) — the app fails loudly at import time
# if any is missing, rather than booting with a silent default.

DJANGO_SECRET_KEY=
DATABASE_URL=postgres://user:password@host:5432/dbname
SIMPLE_JWT_SIGNING_KEY=

# Behavioral knobs — safe defaults exist for these (CLAUDE.md rule 5),
# only set them to override.
DJANGO_DEBUG=
DJANGO_ALLOWED_HOSTS=
