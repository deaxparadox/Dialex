# Copy to .env and fill in real values. Both are required at startup —
# pydantic-settings raises a validation error immediately if either is
# missing, rather than booting with a silent default.

DATABASE_URL=postgres://user:password@host:5432/dbname
# Must match Django's SIMPLE_JWT_SIGNING_KEY exactly (decision 13) — this
# is a shared secret between the two services, not two independent keys.
JWT_SIGNING_KEY=
# spec 0005 — participant/judge LLM calls (user's choice: OpenAI for this milestone).
OPENAI_API_KEY=
# Temporal server address — e.g. temporal:7233 inside docker-compose.
TEMPORAL_ADDRESS=temporal:7233
